{
  "name": "flagbase-sdk",
  "version": "0.1.0",
  "description": "Self-hosted feature flag SDK powered by Firebase",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "feature-flags",
    "firebase",
    "feature-toggles",
    "launchdarkly-alternative"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fadixsrourr/flagbase.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/fadixsrourr/flagbase#readme",
  "bugs": "https://github.com/fadixsrourr/flagbase/issues",
  "peerDependencies": {
    "firebase": ">=11"
  },
  "devDependencies": {
    "@flagbase/types": "workspace:*",
    "firebase": "^11.3.1",
    "firebase-admin": "^14.0.0",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
