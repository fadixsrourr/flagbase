{
  "name": "flagbase-react",
  "version": "0.1.0",
  "description": "React hooks for FlagBase feature flags",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "feature-flags",
    "firebase",
    "react",
    "react-hooks",
    "feature-toggles"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fadixsrourr/flagbase.git",
    "directory": "packages/sdk-react"
  },
  "homepage": "https://github.com/fadixsrourr/flagbase#readme",
  "bugs": "https://github.com/fadixsrourr/flagbase/issues",
  "peerDependencies": {
    "react": ">=18",
    "firebase": ">=11"
  },
  "dependencies": {
    "flagbase-sdk": "workspace:*"
  },
  "devDependencies": {
    "@flagbase/types": "workspace:*",
    "@types/react": "^18.3.18",
    "react": "^18.3.1",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  }
}
