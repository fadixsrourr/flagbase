rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: check if the user owns the project
    function isProjectOwner(projectId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
    }

    // Projects: owner read/write only
    match /projects/{projectId} {
      allow read, write: if isProjectOwner(projectId);

      // Environments: project owner only. The apiKey lives here, so this doc
      // must never be world-readable.
      match /environments/{environmentKey} {
        allow read, write: if isProjectOwner(projectId);

        // Flags: read is PUBLIC by design. The client SDK evaluates flags in the
        // browser via an unauthenticated onSnapshot, so the flag config is shipped
        // to clients anyway (same model as client-side LaunchDarkly). The project
        // id is an unguessable Firestore id and is embedded in the consumer app.
        // Writes stay owner-only; mutations go through the server API (Admin SDK).
        match /flags/{flagId} {
          allow read: if true;
          allow write: if isProjectOwner(projectId);

          // Audit log: project owner can read, nobody can write directly (server API routes only, via Admin SDK)
          match /audit/{auditId} {
            allow read: if isProjectOwner(projectId);
            allow write: if false;
          }
        }
      }
    }
  }
}
